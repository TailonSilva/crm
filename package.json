{
  "name": "connecta-crm",
  "version": "1.4.1",
  "private": true,
  "description": "Connecta CRM com Electron, React, Express e SQLite.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:webapp": "concurrently -k \"npm:dev:backend\" \"npm:dev:web\"",
    "dev:backend": "nodemon scripts/iniciarBackendDev.js",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:3101 tcp:5174 && node scripts/abrirElectron.js .",
    "start:backend": "node scripts/iniciarBackendLocal.js",
    "start:web": "vite",
    "start:electron": "npm run build:web && node scripts/abrirElectron.js .",
    "build": "npm run build:web",
    "build:web": "vite build",
    "build:electron": "npm run build:web && node scripts/executarElectronBuilder.js",
    "release": "npm run build:web && node scripts/executarElectronBuilder.js --publish always",
    "popular:banco": "node scripts/popularBancoLocal.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.10",
    "vite": "^7.1.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.crm.desktop",
    "productName": "Connecta CRM",
    "artifactName": "Connecta-CRM-Setup-${version}.${ext}",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist/electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "TailonSilva",
        "repo": "connecta-crm"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/web/**/*",
      "package.json"
    ]
  }
}
